{
  "name": "kanban-board-monorepo",
  "private": true,
  "workspaces": [
    "apps/client",
    "apps/api"
  ],
  "scripts": {
    "client:dev": "npm run dev --workspace apps/client",
    "api:dev": "npm run start:dev --workspace apps/api",
    "dev": "concurrently \"npm run api:dev\" \"npm run client:dev\"",
    "client:build": "npm run build --workspace apps/client",
    "api:build": "npm run build --workspace apps/api",
    "build": "npm run client:build && npm run api:build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "devDependencies": {
    "concurrently": "latest",
    "prisma": "latest"
  },
  "dependencies": {
    "@prisma/client": "latest",
    "@prisma/adapter-pg": "latest",
    "pg": "latest",
    "dotenv": "latest"
  }
}
